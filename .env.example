# CareerBoost — local configuration only (this file is safe to commit; it has no real values).
#
# Privacy: CareerBoost is local-first — SQLite + AsyncStorage on the device. Optional keys here are only for
# client-side calls you opt into (e.g. weather). `EXPO_PUBLIC_*` values are inlined at build time — they are not
# hidden from the app bundle. Treat keys as “not in git” (use .env locally) and restrict usage in the provider’s
# dashboard (e.g. OpenWeather call limits / referrer rules). For truly secret keys, use a backend proxy instead.
#
# Copy to ".env" on your machine (never commit .env). Restart Expo after edits.

# OpenWeatherMap – https://openweathermap.org/api (Current Weather Data). Used on the Insights tab. Leave empty to disable.
EXPO_PUBLIC_OPENWEATHER_API_KEY=

# Optional: default city for current weather (no GPS). Falls back to London if unset.
# EXPO_PUBLIC_OPENWEATHER_CITY=Dublin
EXPO_PUBLIC_OPENWEATHER_CITY=
